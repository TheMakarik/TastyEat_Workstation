<UserControl
    x:Class="TastyEat.Workstation.Views.Controls.LoadingControl"
    x:CompileBindings="False"
    x:DataType="vm:LoadingControlViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        Background="#E5FFFFFF"
        IsVisible="{Binding IsLoading, FallbackValue=False}">
        <TextBlock
            FontSize="18"
            FontWeight="SemiBold"
            HorizontalAlignment="Center"
            Text="{Binding DisplayText}"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
