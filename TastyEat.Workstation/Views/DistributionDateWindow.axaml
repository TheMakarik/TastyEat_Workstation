<reactive:ReactiveWindow
    CanResize="False"
    Height="240"
    Title="Добавить запись о развозе"
    Width="400"
    WindowStartupLocation="CenterOwner"
    x:Class="TastyEat.Workstation.Views.DistributionDateWindow"
    x:DataType="vm:DistributionDateViewModel"
    x:TypeArguments="vm:DistributionDateViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:reactive="http://reactiveui.net"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:DistributionDateViewModel />
    </Design.DataContext>

    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Text="Добавить запись о развозе" />

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Spacing="4">
            <TextBlock Text="Дата развоза" />
            <DatePicker SelectedDate="{Binding Date}" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Command="{Binding SaveCommand}"
                Content="Сохранить"
                IsDefault="True" />
            <Button
                Click="CancelButton_Click"
                Content="Отмена"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</reactive:ReactiveWindow>
