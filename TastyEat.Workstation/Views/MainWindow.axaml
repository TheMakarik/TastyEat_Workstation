<Window
    Height="800"
    Title="Кушай Вкусно! - Рабочая станция"
    Width="1200"
    x:Class="TastyEat.Workstation.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:conv="using:TastyEat.Workstation.Views.Converters"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:views="using:TastyEat.Workstation.Views"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <conv:StringToIconKindConverter x:Key="StringToIconKindConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TabControl.sidebar">
            <Setter Property="TabStripPlacement" Value="Top" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="16,0,6,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:selected /template/ ContentPresenter#PART_ContentPresenter icons|MaterialIcon">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <TabControl
        Classes="sidebar"
        ItemsSource="{Binding TabItems}"
        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
        x:Name="MainTabControl">
        <TabControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </TabControl.ItemsPanel>
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <DockPanel>
                    <ScrollViewer
                        DockPanel.Dock="Top"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        x:Name="TabScrollViewer">
                        <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" Name="PART_ItemsPresenter" />
                    </ScrollViewer>
                    <ContentPresenter
                        Content="{TemplateBinding SelectedContent}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        Name="PART_SelectedContentHost" />
                </DockPanel>
            </ControlTemplate>
        </TabControl.Template>
        <TabControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:ViewModelBase}">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="20">
                    <icons:MaterialIcon
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                        Height="22"
                        Kind="{Binding IconName, Converter={StaticResource StringToIconKindConverter}}"
                        Width="22" />
                    <TextBlock
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                        Margin="0,0,10,0"
                        Text="{Binding Title}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
            <DataTemplate DataType="{x:Type vm:ViewModelBase}">
                <ContentControl Content="{Binding}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
                            <views:ClientsView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
                            <views:ProductsView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProductionsViewModel}">
                            <views:ProductionsView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:OrderCollectionViewModel}">
                            <views:OrderCollectionView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:AdministrationViewModel}">
                            <views:AdministrationView DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DataTemplate>
        </TabControl.ContentTemplate>
    </TabControl>
</Window>
