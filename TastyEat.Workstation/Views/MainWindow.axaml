<Window
    Height="800"
    Title="TastyEat Workstation"
    Width="1200"
    x:Class="TastyEat.Workstation.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:conv="using:TastyEat.Workstation.Views.Converters"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:views="using:TastyEat.Workstation.Views"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <conv:StringToIconKindConverter x:Key="StringToIconKindConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TabControl.sidebar">
            <Setter Property="TabStripPlacement" Value="Top" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem">
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="TabControl.sidebar TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
            <Setter Property="TextBlock.Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <TabControl
        Classes="sidebar"
        ItemsSource="{Binding TabItems}"
        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:ViewModelBase}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <icons:MaterialIcon
                        Height="22"
                        Kind="{Binding IconName, Converter={StaticResource StringToIconKindConverter}}"
                        Width="22" />
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
            <DataTemplate DataType="{x:Type vm:ViewModelBase}">
                <ContentControl Content="{Binding}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
                            <views:ClientsView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
                            <views:ProductsView DataContext="{Binding}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:AnalyticsViewModel}">
                            <views:AnalyticsView DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DataTemplate>
        </TabControl.ContentTemplate>
    </TabControl>
</Window>
