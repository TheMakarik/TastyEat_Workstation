<Window
    Height="600"
    Title="{Binding Title}"
    Width="800"
    x:Class="TastyEat.Workstation.Views.PieChartWindow"
    x:DataType="vm:PieChartViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="using:TastyEat.Workstation.Views.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:PieChartViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Margin="24,24,24,0"
            Text="{Binding ChartTitle}" />

        <lvc:PieChart
            Grid.Row="1"
            LegendPosition="Right"
            Margin="24"
            Series="{Binding Series}" />

        <controls:LoadingControl
            DataContext="{Binding Loading}"
            Grid.Row="0"
            Grid.RowSpan="2" />
    </Grid>
</Window>
