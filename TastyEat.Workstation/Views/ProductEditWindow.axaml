<reactive:ReactiveWindow
    CanResize="False"
    Height="420"
    Title="{Binding Title}"
    Width="480"
    WindowStartupLocation="CenterOwner"
    x:Class="TastyEat.Workstation.Views.ProductEditWindow"
    x:CompileBindings="False"
    x:DataType="vm:ProductEditViewModel"
    x:TypeArguments="vm:ProductEditViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:reactive="http://reactiveui.net"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:ProductEditViewModel />
    </Design.DataContext>

    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock Text="Название" />
                <TextBox PlaceholderText="Введите название продукта" Text="{Binding Name}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Тип продукта" />
                <ComboBox
                    DisplayMemberBinding="{Binding Name}"
                    ItemsSource="{Binding ProductTypes}"
                    PlaceholderText="Выберите тип"
                    SelectedItem="{Binding SelectedProductType}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Цена" />
                <NumericUpDown
                    Increment="1"
                    Minimum="0"
                    Value="{Binding Price}" />
            </StackPanel>

            <CheckBox
                Content="Использовать вес (цена за 1 кг)"
                IsChecked="{Binding IsWeighted}"
                Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Command="{Binding SaveCommand}"
                Content="Сохранить"
                IsDefault="True" />
            <Button
                Click="CancelButton_Click"
                Content="Отмена"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</reactive:ReactiveWindow>
