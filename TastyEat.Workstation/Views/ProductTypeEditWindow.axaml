<reactive:ReactiveWindow
    CanResize="False"
    Height="220"
    Title="{Binding Title}"
    Width="400"
    WindowStartupLocation="CenterOwner"
    x:Class="TastyEat.Workstation.Views.ProductTypeEditWindow"
    x:DataType="vm:ProductTypeEditViewModel"
    x:TypeArguments="vm:ProductTypeEditViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:reactive="http://reactiveui.net"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:ProductTypeEditViewModel />
    </Design.DataContext>

    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Spacing="4">
            <TextBlock Text="Название типа продукта" />
            <TextBox Text="{Binding Name}" PlaceholderText="Введите название типа" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Command="{Binding SaveCommand}"
                Content="Сохранить"
                IsDefault="True" />
            <Button
                Click="CancelButton_Click"
                Content="Отмена"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</reactive:ReactiveWindow>
