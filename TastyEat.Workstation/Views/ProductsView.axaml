
<reactive:ReactiveUserControl
    x:Class="TastyEat.Workstation.Views.ProductsView"
    x:CompileBindings="False"
    x:DataType="vm:ProductsViewModel"
    x:Name="Root"
    x:TypeArguments="vm:ProductsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="using:TastyEat.Workstation.Views.Controls"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:reactive="http://reactiveui.net"
    xmlns:vm="using:TastyEat.Workstation.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:ProductsViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <DataTemplate DataType="vm:ProductNodeViewModel" x:Key="ProductActionsCellTemplate">
            <Button Classes="action">
                <icons:MaterialIcon Kind="Menu" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuItem
                            Command="{Binding #Root.DataContext.EditNodeCommand}"
                            CommandParameter="{Binding}"
                            Header="Изменить тип"
                            IsVisible="{Binding IsProductType}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Pencil" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem
                            Command="{Binding #Root.DataContext.DeleteNodeCommand}"
                            CommandParameter="{Binding}"
                            Header="Удалить тип"
                            IsVisible="{Binding IsProductType}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Delete" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem
                            Command="{Binding #Root.DataContext.EditNodeCommand}"
                            CommandParameter="{Binding}"
                            Header="Изменить продукт"
                            IsVisible="{Binding IsProduct}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Pencil" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem
                            Command="{Binding #Root.DataContext.DeleteNodeCommand}"
                            CommandParameter="{Binding}"
                            Header="Удалить продукт"
                            IsVisible="{Binding IsProduct}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Delete" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Classes="managementLayout" RowDefinitions="Auto,Auto,*">
        <controls:SectionHeader
            Grid.Row="0"
            IconKind="PackageVariant"
            Subtitle="Управление товарами, типами и ценами"
            Title="Товары" />

        <Grid
            Classes="topbar"
            ColumnDefinitions="*,Auto"
            Grid.Row="1">
            <controls:SearchTextBox
                Grid.Column="0"
                HorizontalAlignment="Left"
                Text="{Binding SearchText}"
                Width="320" />

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="12">
                <Button Classes="sidebarAction" Command="{Binding AddProductTypeCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <icons:MaterialIcon Kind="ShapeOutline" />
                        <TextBlock Text="Добавить тип" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="accent" Command="{Binding AddProductCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <icons:MaterialIcon Kind="Plus" />
                        <TextBlock Text="Добавить продукт" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Classes="dataGridHost" Grid.Row="2">
            <TreeDataGrid Source="{Binding ProductsSource}" />
        </Border>
    </Grid>
</reactive:ReactiveUserControl>
