<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:models="using:TastyEat.Workstation.Models.Tables"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TextBox -->
    <Style Selector="TextBox /template/ Border#PART_ContentPresenterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="TextBox:pointerover /template/ Border#PART_ContentPresenterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_ContentPresenterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="TextBox:disabled /template/ Border#PART_ContentPresenterBorder">
        <Setter Property="BorderBrush" Value="#CCCCCC" />
    </Style>

    <!-- CheckBox -->
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle,
                   CheckBox:indeterminate /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle,
                   CheckBox:indeterminate:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="CheckBox:checked:pressed /template/ Border#NormalRectangle,
                   CheckBox:indeterminate:pressed /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource AccentColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="ComboBox:dropdownopen /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <!-- ComboBoxItem -->
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <!-- AutoCompleteBox -->
    <Style Selector="AutoCompleteBox">
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="PlaceholderForeground" Value="#666666" />
        <Setter Property="IsTextCompletionEnabled" Value="False" />
        <Setter Property="ItemTemplate">
            <DataTemplate DataType="models:Client">
                <TextBlock Foreground="#333333" Text="{Binding FullName}" />
            </DataTemplate>
        </Setter>
    </Style>

    <Style Selector="AutoCompleteBox:focus">
        <Setter Property="Foreground" Value="#333333" />
        <Setter Property="PlaceholderForeground" Value="#666666" />
    </Style>

    <Style Selector="AutoCompleteBox /template/ TextBox#PART_TextBox">
        <Setter Property="Foreground" Value="#333333" />
    </Style>

    <Style Selector="AutoCompleteBox /template/ TextBox#PART_TextBox:focus">
        <Setter Property="Foreground" Value="#333333" />
    </Style>

    <Style Selector="AutoCompleteBox /template/ TextBox#PART_TextBox:disabled">
        <Setter Property="Foreground" Value="#333333" />
    </Style>

    <!-- NumericUpDown: spinner buttons work, keyboard input disabled -->
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox">
        <Setter Property="IsReadOnly" Value="True" />
    </Style>

    <Style Selector="NumericUpDown /template/ ButtonSpinner#PART_Spinner">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    </Style>

    <Style Selector="NumericUpDown:pointerover /template/ ButtonSpinner#PART_Spinner">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style Selector="NumericUpDown:focus /template/ ButtonSpinner#PART_Spinner">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}" />
    </Style>

</Styles>
